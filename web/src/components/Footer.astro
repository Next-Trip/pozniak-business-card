---
import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);
---

<footer
  class="w-full border-t border-brand-primary/10 bg-brand-tertiary dark:bg-brand-tertiary"
  id="footer"
>
  <div
    class="max-w-7xl mx-auto px-6 md:px-16 py-16 flex flex-col md:flex-row justify-between items-center gap-gutter"
  >
    <div
      class="font-headline-lg text-brand-primary text-center md:text-left mb-6 md:mb-0"
    >
      {t("site.hero_name")}
    </div>
    <nav class="flex gap-6 mb-6 md:mb-0">
      <a
        class="font-label-sm uppercase text-brand-primary-on-surface hover:text-brand-secondary transition-colors duration-200"
        href="#"
        >EPK
      </a>
      <a
        class="font-label-sm uppercase text-brand-primary-on-surface hover:text-brand-secondary transition-colors duration-200"
        href="#"
        >Contact
      </a>
      <a
        class="font-label-sm uppercase text-brand-primary-on-surface hover:text-brand-secondary transition-colors duration-200"
        href="#"
        >Privacy
      </a>
    </nav>
    <div
      class="font-label-sm uppercase text-brand-primary-on-surface text-center md:text-right"
    >
      © 2026 Veronika Pozniak. ALL RIGHTS RESERVED.
    </div>
  </div>
</footer>
