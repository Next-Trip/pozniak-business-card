---
import Breadcrumb from "../../components/Breadcrumb.astro";
import { useTranslations } from "../../i18n/ui";
const t = useTranslations(Astro.currentLocale);

import bioData from "../../data/bio.json";
const content = bioData[(Astro.currentLocale ?? "en") as keyof typeof bioData];

import { getImage } from "astro:assets";

import backgroundImage from "../../assets/bg.svg";
const optimizedBackground = await getImage({ src: backgroundImage });

import { marked } from "marked";
const bio_description = marked.parse(content.content);
---

<main>
  <div
    class="fixed inset-0 z-0 pointer-events-none opacity-20"
    style={`background-image: url(${optimizedBackground.src}); background-repeat: no-repeat; background-size: cover; background-position: center; background-attachment: fixed;`}
  >
  </div>
  <div
    class="relative z-10 min-h-screen max-w-200 mx-auto bg-[#f7f3ef] pt-16 my-0 pb-24 md:my-32 px-6 md:px-14"
  >
    <Breadcrumb
      segments={[
        {
          title: t("site.page_title.index"),
          href: import.meta.env.BASE_URL || "/",
        },
        { title: t("site.page_title.about") },
      ]}
    />

    <article class="relative z-10">
      <div class="mb-20">
        <h1 class="text-5xl md:text-7xl text-brand-primary leading-tight mb-8">
          {content.title}
        </h1>
        <div class="h-px w-24 bg-brand-primary/30"></div>
      </div>

      <article class="prose" set:html={bio_description} />

      <!-- <div
