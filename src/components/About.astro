---
import { Image } from "astro:assets";
import aboutImage from "../assets/images/about-side.jpg";
import { getRelativeLocaleUrl } from "astro:i18n";

import homepageData from "../data/homepage.json";
const content =
  homepageData[(Astro.currentLocale ?? "en") as keyof typeof homepageData];

import { marked } from "marked";
const about_description = marked.parse(content.about_description);

import { useTranslations } from "../i18n/ui";
import type { Locale } from "../i18n/ui";
const locale = Astro.currentLocale as Locale;
const t = useTranslations(locale);
---

<section class="py-32 px-6 md:px-16 fade-in-section" id="about">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row gap-16 items-center">
      <div class="w-full md:w-5/12 relative">
        <div class="aspect-3/4 relative overflow-hidden rounded-sm">
          <Image
            class="w-full h-full object-cover"
            src={aboutImage}
            alt="About photo."
          />
        </div>
      </div>
      <div class="w-full md:w-7/12 md:pl-12">
        <h2
          class="font-headline-lg-mobile md:font-headline-lg text-brand-primary mb-8 relative inline-block"
        >
          {content.about_title}
          <span class="absolute -bottom-2 left-0 w-1/3 h-px bg-brand-primary"
          ></span>
        </h2>
        <div
          class="font-body-lg text-body-lg text-on-surface-variant space-y-6 max-w-2xl"
        >
          <article class="prose" set:html={about_description} />
        </div>
        <div class="mt-12 flex justify-end gap-6">
          <a
            class="inline-flex px-6 py-3 border border-brand-primary font-label-sm uppercase tracking-widest hover:bg-brand-primary text-brand-primary hover:text-[#F1EDE4] transition-all"
            href={getRelativeLocaleUrl(Astro.currentLocale ?? "en", "about")}
          >
            <span>{t("about.cta")}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
