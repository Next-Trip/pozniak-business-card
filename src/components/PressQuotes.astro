---
import { Icon } from "astro-icon/components";
---

<section class="py-32 px-6 md:px-16 fade-in-section" id="press">
  <div class="max-w-4xl mx-auto text-center">
    <div class="flex justify-center">
      <Icon
        name="mdi:format-quote-close"
        class="text-brand-primary"
        width="64"
        height="64"
      />
    </div>
    <div class="max-w-3xl mx-auto">
      <p
        class="font-headline-md text-brand-primary italic mb-8 leading-relaxed"
      >
        "A masterful display of vocal control and profound emotional depth. Voss
        does not just sing notes; she breathes life into the very silence
        between them."
      </p>
      <div
        class="font-label-sm text-brand-primary-on-surface uppercase tracking-widest"
      >
        — The Classical Review
      </div>
    </div>
  </div>
</section>
