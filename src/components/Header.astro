---
import { Icon } from "astro-icon/components";
import LanguageDropdown from "./LanguageDropdown.astro";

import { getRelativeLocaleUrl } from "astro:i18n";

import { useTranslations } from "../i18n/ui";
import type { UiKey } from "../i18n/ui";

const t = useTranslations(Astro.currentLocale);

const navItems: { labelKey: UiKey; href: string }[] = [
  {
    labelKey: "site.nav_about",
    href: getRelativeLocaleUrl(Astro.currentLocale ?? "en", "about"),
  },
  { labelKey: "site.nav_events", href: "#events" },
  { labelKey: "site.nav_press", href: "#press" },
  { labelKey: "site.nav_gallery", href: "#gallery" },
  { labelKey: "site.nav_contacts", href: "#footer" },
];
---

<div
  class="mt-(--header-height) fixed inset-0 bg-brand-tertiary/95 z-60 hidden flex-col p-6 transition-opacity duration-300"
  id="mobile-nav-overlay"
>
  <nav class="flex flex-col space-y-8 mt-12">
    {
      navItems.map((item) => (
        <a
          class="mobile-nav-link font-headline-md text-brand-primary hover:pl-4 transition-all duration-300 ease-in-out border-b border-brand-primary/20 pb-4"
          href={item.href}
        >
          {t(item.labelKey)}
        </a>
      ))
    }
  </nav>

  <div class="pt-8">
    <LanguageDropdown
      class="flex gap-2 items-center font-body-lg uppercase"
      variant="inline"
    />
  </div>
</div>

<header
  class="fixed h-(--header-height) top-0 w-full z-50 backdrop-blur-md bg-brand-tertiary/80 text-brand-primary"
>
  <div
    class="flex justify-between items-center px-6 md:pl-16 md:pr-6 py-2 h-20 max-w-7xl mx-auto"
  >
    <a
      class="font-headline-md uppercase tracking-tighter"
      href={getRelativeLocaleUrl(Astro.currentLocale ?? "en", "")}
      >{t("site.hero_name")}
    </a>

    <button
      class="md:hidden text-brand-primary cursor-pointer transition-all active:opacity-70"
      id="open-menu-btn"
      aria-expanded="false"
      aria-label="Toggle menu"
    >
      <Icon
        name="mdi:menu"
        width="32"
        height="32"
        class="menu-icon-open transition-all duration-200"
      />
      <Icon
        name="mdi:close"
        width="32"
        height="32"
        class="menu-icon-close transition-all duration-200 hidden"
      />
    </button>

    <nav class="hidden md:flex space-x-8">
      {
        navItems.map((item) => (
          <a
            class="text-body-md uppercase tracking-widest text-brand-primary-on-surface hover:text-brand-primary transition-colors duration-300"
            href={item.href}
          >
            {t(item.labelKey)}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:flex space-x-2">
      <LanguageDropdown />
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("open-menu-btn");
    const closebutton = document.getElementById("close-menu-btn");
    const menu = document.getElementById("mobile-nav-overlay");
    const navLinks = document.querySelectorAll(".mobile-nav-link");

    button?.addEventListener("click", toggleMenu);
    closebutton?.addEventListener("click", toggleMenu);

    navLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    function toggleMenu() {
      const isExpanded = button?.getAttribute("aria-expanded") === "true";
      const nextExpanded = !isExpanded;
      button?.setAttribute("aria-expanded", nextExpanded.toString());

      const iconOpen = button?.querySelector(".menu-icon-open");
      const iconClose = button?.querySelector(".menu-icon-close");
      iconOpen?.classList.toggle("hidden", nextExpanded);
      iconClose?.classList.toggle("hidden", !nextExpanded);

      menu?.classList.toggle("hidden");
      menu?.classList.toggle("flex");
    }

    function closeMenu() {
      button?.setAttribute("aria-expanded", "false");

      const iconOpen = button?.querySelector(".menu-icon-open");
      const iconClose = button?.querySelector(".menu-icon-close");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");

      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
    }
  });
</script>
