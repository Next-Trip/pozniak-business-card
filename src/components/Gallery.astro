---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import EmblaCarousel from "./EmblaCarousel.astro";

import galleryData from "../data/gallery.json";

import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif}",
);

const videos = [
  "https://youtu.be/iNV6qxNMBRo?si=s4bdIJ_qBlCZXuTs",
  "https://youtu.be/dpGln87XeUI?si=uBji4iXXDwTGZa6v",
];

function youTubeGetID(url: string) {
  const [a, , b] = url
    .replace(/(>|<)/gi, "")
    .split(
      /^.*(?:(?:youtu\.?be(\.com)?\/|v\/|vi\/|u\/\w\/|embed\/|shorts\/)|(?:(?:watch)?\?v(?:i)?=|\&v(?:i)?=))([^#\&\?]*).*/,
    );
  if (b !== undefined) {
    return b.split(/[^0-9a-z_-]/i)[0];
  } else {
    return a;
  }
}
---

<section class="py-16 px-6 md:px-16 fade-in-section" id="gallery">
  <div class="max-w-7xl mx-auto">
    <h2
      class="font-headline-lg-mobile md:font-headline-lg text-brand-primary mb-12 text-center"
    >
      {t("gallery.title")}
    </h2>

    <EmblaCarousel showArrows={true}>
      {
        galleryData.carousel_photos.map((photo: any) => {
          const imagePath = "/" + photo.image;
          if (!images[imagePath]) {
            console.error(`Image not found: ${imagePath}`);
            return null;
          }
          return (
            <div class="embla__slide">
              <Image
                layout="constrained"
                src={images[imagePath]()}
                alt="Cover image."
                class="embla__slide__img"
              />
            </div>
          );
        })
      }
    </EmblaCarousel>
  </div>
</section>

<section class="py-16 px-6 md:px-16 bg-[#f7f3ef] fade-in-section" id="gallery">
  <div class="max-w-7xl mx-auto">
    <h2
      class="font-headline-lg-mobile md:font-headline-lg text-brand-primary mb-12 text-center"
    >
      Videos
    </h2>
    <EmblaCarousel showDots={true} showArrows={true}>
      {
        videos.map((video) => {
          const videoId = youTubeGetID(video);
          return (
            <div class="embla__slide">
              {videoId ? (
                <lite-youtube
                  videoid={videoId}
                  posterquality="maxresdefault"
                  posterloading="lazy"
                />
              ) : null}
            </div>
          );
        })
      }
    </EmblaCarousel>
  </div>
</section>
